{
  "manifest_version": 3,
  "name": "Jarvis Login State Transfer",
  "description": "Export and import website login state between Chrome and Jarvis Browser.",
  "version": "0.1.0",
  "action": {
    "default_title": "Login State Transfer",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "state-format.js",
        "content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
